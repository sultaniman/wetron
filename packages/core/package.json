{
  "name": "@wetron/core",
  "version": "0.0.8",
  "description": "IR types, format detection, dtype utilities and layout transform for neural network graph visualization",
  "keywords": [
    "graph",
    "keras",
    "model-viewer",
    "neural-network",
    "onnx",
    "tflite",
    "visualization"
  ],
  "homepage": "https://codeberg.org/askar/wetron",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/askar/wetron.git",
    "directory": "packages/core"
  },
  "files": [
    "README.md",
    "dist",
    "llms.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ir": {
      "source": "./src/ir.ts",
      "types": "./dist/ir.d.ts",
      "import": "./dist/ir.js"
    },
    "./dtypes": {
      "source": "./src/dtypes.ts",
      "types": "./dist/dtypes.d.ts",
      "import": "./dist/dtypes.js"
    },
    "./detect": {
      "source": "./src/detect.ts",
      "types": "./dist/detect.d.ts",
      "import": "./dist/detect.js"
    },
    "./transform": {
      "source": "./src/transform.ts",
      "types": "./dist/transform.d.ts",
      "import": "./dist/transform.js"
    },
    "./edge-path": {
      "source": "./src/edge-path.ts",
      "types": "./dist/edge-path.d.ts",
      "import": "./dist/edge-path.js"
    },
    "./panel-utils": {
      "source": "./src/panel-utils.ts",
      "types": "./dist/panel-utils.d.ts",
      "import": "./dist/panel-utils.js"
    }
  },
  "dependencies": {
    "@wetron/executorch": "workspace:*",
    "@wetron/keras": "workspace:*",
    "@wetron/onnx": "workspace:*",
    "@wetron/savedmodel": "workspace:*",
    "@wetron/tflite": "workspace:*",
    "@wetron/torchscript": "workspace:*",
    "dagre": "^0.8.5",
    "fflate": "^0.8.2",
    "flatbuffers": "^25.9.23",
    "protobufjs": "^8.0.3"
  }
}
