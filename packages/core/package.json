{
  "name": "@wetron/core",
  "version": "0.0.1",
  "description": "IR types, format detection, dtype utilities and layout transform for neural network graph visualization",
  "keywords": [
    "graph",
    "keras",
    "model-viewer",
    "neural-network",
    "onnx",
    "tflite",
    "visualization"
  ],
  "homepage": "https://codeberg.org/askar/wetron",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/askar/wetron.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./ir": { "types": "./dist/ir.d.ts", "import": "./dist/ir.js" },
    "./dtypes": { "types": "./dist/dtypes.d.ts", "import": "./dist/dtypes.js" },
    "./detect": { "types": "./dist/detect.d.ts", "import": "./dist/detect.js" },
    "./transform": { "types": "./dist/transform.d.ts", "import": "./dist/transform.js" },
    "./edge-path": { "types": "./dist/edge-path.d.ts", "import": "./dist/edge-path.js" },
    "./panel-utils": { "types": "./dist/panel-utils.d.ts", "import": "./dist/panel-utils.js" }
  },
  "dependencies": {
    "@wetron/keras": "workspace:*",
    "@wetron/onnx": "workspace:*",
    "@wetron/tflite": "workspace:*",
    "dagre": "^0.8.5"
  }
}
